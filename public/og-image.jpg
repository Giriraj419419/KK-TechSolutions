<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0B121F"/>
      <stop offset="50%" stop-color="#0F172A"/>
      <stop offset="100%" stop-color="#1E293B"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#3B82F6"/>
      <stop offset="100%" stop-color="#60A5FA"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <rect x="0" y="0" width="1200" height="8" fill="url(#accent)"/>
  <circle cx="1000" cy="150" r="300" fill="#2563EB" opacity="0.08"/>
  <circle cx="200" cy="500" r="250" fill="#3B82F6" opacity="0.05"/>
  <g transform="translate(100, 180)">
    <text x="0" y="80" font-family="system-ui, -apple-system, sans-serif" font-weight="900" font-size="64" fill="#FFFFFF" letter-spacing="-1">KK TECH SOLUTIONS</text>
    <text x="0" y="140" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="32" fill="#60A5FA">Enterprise IT Infrastructure &amp; Cloud Solutions</text>
    <text x="0" y="210" font-family="system-ui, -apple-system, sans-serif" font-weight="400" font-size="24" fill="#94A3B8">Microsoft 365 | Azure | AWS | Adobe | Autodesk | Dell | HPE | Lenovo</text>
    <rect x="0" y="270" width="360" height="50" rx="25" fill="url(#accent)"/>
    <text x="180" y="303" font-family="system-ui, -apple-system, sans-serif" font-weight="700" font-size="20" fill="#FFFFFF" text-anchor="middle">https://kktechsolutions.in</text>
  </g>
</svg>